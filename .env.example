# Keepa API (price history)
KEEPA_API_KEY=your_keepa_api_key_here

# Amazon Product Advertising API (PA API 5.0)
PA_API_ACCESS_KEY=your_access_key
PA_API_SECRET_KEY=your_secret_key
PA_API_PARTNER_TAG=your-tag-20
PA_API_HOST=webservices.amazon.com
PA_API_REGION=us-east-1

# Mailchimp (for sending newsletters)
# Get API key from: https://us5.admin.mailchimp.com/account/api/
# Get Audience ID from: Audience > Settings > Audience name and defaults
MAILCHIMP_API_KEY=your-api-key-us5
MAILCHIMP_LIST_ID=your-audience-id
MAILCHIMP_FROM_NAME=Recomendo Deals
MAILCHIMP_REPLY_TO=your@email.com
